# Database Configuration
DATABASE_URL=postgres://admin:password@localhost:5432/gatewayforge?sslmode=disable

# API Configuration
PORT=8080
ENV=development

# Claude Authentication Method
# Options: "api" (API key) or "desktop" (Claude Desktop via MCP)
CLAUDE_AUTH_MODE=desktop

# Claude API Key (only required if CLAUDE_AUTH_MODE=api)
CLAUDE_API_KEY=your_claude_api_key_here

# Claude Desktop MCP (only required if CLAUDE_AUTH_MODE=desktop)
CLAUDE_MCP_ENDPOINT=http://localhost:52828

# Temporal Configuration
TEMPORAL_URL=localhost:7233

# Redis
REDIS_URL=redis://localhost:6379

# S3/MinIO Storage
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=gatewayforge-artifacts
S3_REGION=us-east-1

# Monitoring
PROMETHEUS_URL=http://localhost:9090
GRAFANA_URL=http://localhost:3000

# Security
JWT_SECRET=your_jwt_secret_here
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=your_vault_token_here

# Email/Notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@razorpay.com
SMTP_PASSWORD=your_password

# Slack (Optional)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url

# GitHub (for PR creation)
GITHUB_TOKEN=your_github_token_here
GITHUB_ORG=razorpay

# Feature Flags
ENABLE_AUTO_APPROVAL=false
ENABLE_PARALLEL_EXECUTION=true
MAX_CONCURRENT_INTEGRATIONS=5

# Cost Tracking
CLAUDE_COST_PER_1K_TOKENS=0.003

# Log Level
LOG_LEVEL=info
